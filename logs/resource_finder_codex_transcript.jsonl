{"type":"item.started","item":{"id":"item_30","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - << 'PY'\nimport json, re, glob, os\nwith open('papers/manual_search_results.json') as f:\n    rows=json.load(f)\n\n# Build slug map from rows\nslug_map={}\nfor r in rows:\n    title=r.get('title') or ''\n    slug=re.sub(r'[\"'^a-zA-Z0-9]+'\"','_',title).strip('_').lower()[:70]\n    y=str(r.get('year') or 'unknown')\n    fn=f\\\"{y}_{slug}.pdf\\\"\n    slug_map[fn]=r\n\nmeta=[]\nfor path in sorted(glob.glob('papers/*.pdf')):\n    base=os.path.basename(path)\n    r=slug_map.get(base)\n    if not r:\n        # fallback approximate by prefix\n        rnext=None\n        for k,v in slug_map.items():\n            if base[:30]==k[:30]:\n                rnext=v; break\n        r=rnext\n    if r:\n        meta.append({\n            'file': path,\n            'title': r.get('title'),\n            'authors': r.get('authors'),\n            'year': r.get('year'),\n            'abstract': r.get('abstract',''),\n            'pdf_url': r.get('pdf_url',''),\n            'landing_page': r.get('landing_page',''),\n            'doi': r.get('doi',''),\n            'venue': r.get('venue',''),\n            'citations': r.get('cited_by_count',0),\n            'relevance': r.get('relevance',0)\n        })\n    else:\n        meta.append({'file':path,'title':base,'authors':'','year':'','abstract':'','pdf_url':'','landing_page':'','doi':'','venue':'','citations':0,'relevance':0})\n\nwith open('papers/papers_metadata.json','w') as f:\n    json.dump(meta,f,indent=2)\nprint('metadata entries',len(meta))\nfor m in meta:\n    print(os.path.basename(m['file']), '=>', (m['title'] or '')[:80])\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}

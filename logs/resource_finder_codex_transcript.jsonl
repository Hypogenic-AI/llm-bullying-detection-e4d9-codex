{"type":"item.started","item":{"id":"item_19","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nimport arxiv, json, re\nqueries = [\n    'AI-generated text detection large language models',\n    'adversarial attacks AI text detectors',\n    'paraphrasing evade machine generated text detectors',\n    'humanizing llm text style transfer',\n    'watermarking large language models detection'\n]\nseen = {}\nfor q in queries:\n    search = arxiv.Search(query=q, max_results=25, sort_by=arxiv.SortCriterion.Relevance)\n    for r in search.results():\n        if r.entry_id not in seen:\n            seen[r.entry_id] = {\n                'id': r.get_short_id(),\n                'title': r.title.strip().replace('\\\\n',' '),\n                'authors': ', '.join(a.name for a in r.authors[:6]),\n                'year': r.published.year,\n                'summary': re.sub(r'\\\\s+',' ',r.summary).strip(),\n                'pdf_url': r.pdf_url,\n                'entry_id': r.entry_id,\n                'categories': r.categories,\n            }\nresults = list(seen.values())\n# heuristic relevance score\nkw = ['detect','detection','machine-generated','ai-generated','language model','llm','paraphr','rewrite','watermark','adversarial']\nfor r in results:\n    t = (r['title'] + ' ' + r['summary']).lower()\n    r['relevance'] = sum(1 for k in kw if k in t)\nresults.sort(key=lambda x:(x['relevance'],x['year']), reverse=True)\nwith open('papers/manual_search_results.json','w') as f:\n    json.dump(results,f,indent=2)\nprint('total',len(results))\nfor i,r in enumerate(results[:20],1):\n    print(f\\\"{i:02d}. [{r['relevance']}] {r['year']} {r['id']} {r['title']}\\\")\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}

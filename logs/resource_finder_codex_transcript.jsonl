{"type":"item.started","item":{"id":"item_43","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nfrom huggingface_hub import snapshot_download\nfrom pathlib import Path\nimport pandas as pd, json\n\nbase=Path('datasets')\nbase.mkdir(exist_ok=True)\n\n# HC3 raw jsonl files\nhc3_dir = snapshot_download(\n    repo_id='Hello-SimpleAI/HC3',\n    repo_type='dataset',\n    local_dir='datasets/hc3_raw',\n    allow_patterns=['README.md','all.jsonl','finance.jsonl','medicine.jsonl','open_qa.jsonl','reddit_eli5.jsonl','wiki_csai.jsonl']\n)\n\n# ai-text-detection-pile parquet shards\npile_dir = snapshot_download(\n    repo_id='artem9k/ai-text-detection-pile',\n    repo_type='dataset',\n    local_dir='datasets/ai_text_detection_pile',\n    allow_patterns=['README.md','data/*.parquet']\n)\n\n# ghostbuster reuter\nghost_dir = snapshot_download(\n    repo_id='acmc/ghostbuster_reuter',\n    repo_type='dataset',\n    local_dir='datasets/ghostbuster_reuter',\n    allow_patterns=['README.md','data/*.parquet']\n)\n\n# create sample files\nPath('datasets/hc3_raw/samples').mkdir(parents=True, exist_ok=True)\nwith open('datasets/hc3_raw/all.jsonl','r') as f:\n    samples=[]\n    for i,line in enumerate(f):\n        samples.append(json.loads(line))\n        if i>=9: break\nwith open('datasets/hc3_raw/samples/sample.json','w') as f:\n    json.dump(samples,f,indent=2)\n\nPath('datasets/ai_text_detection_pile/samples').mkdir(parents=True, exist_ok=True)\npile_df = pd.read_parquet('datasets/ai_text_detection_pile/data/train-00000-of-00007-bc5952582e004d67.parquet').head(10)\npile_df.to_json('datasets/ai_text_detection_pile/samples/sample.json', orient='records', indent=2)\n\nPath('datasets/ghostbuster_reuter/samples').mkdir(parents=True, exist_ok=True)\nghost_df = pd.read_parquet('datasets/ghostbuster_reuter/data/train-00000-of-00001.parquet').head(10)\nghost_df.to_json('datasets/ghostbuster_reuter/samples/sample.json', orient='records', indent=2)\n\nprint('downloaded dirs:')\nfor d in ['datasets/hc3_raw','datasets/ai_text_detection_pile','datasets/ghostbuster_reuter']:\n    p=Path(d)\n    size=sum(f.stat().st_size for f in p.rglob('*') if f.is_file())\n    print(d, 'files', sum(1 for _ in p.rglob('*') if _.is_file()), 'bytes', size)\nprint('pile columns', list(pile_df.columns))\nprint('ghost columns', list(ghost_df.columns))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}

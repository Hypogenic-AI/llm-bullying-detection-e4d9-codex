{"type":"item.started","item":{"id":"item_23","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nimport requests, json, re, time, urllib.parse\nqueries = [\n  'AI-generated text detection large language models',\n  'adversarial attacks against AI text detectors',\n  'paraphrasing evade machine-generated text detection',\n  'watermarking large language models text',\n  'humanization of LLM text style transfer'\n]\nall_works = {}\nfor q in queries:\n    url = 'https://api.openalex.org/works'\n    params = {\n      'search': q,\n      'per-page': 25,\n      'filter': 'is_paratext:false,language:en',\n      'sort': 'relevance_score:desc'\n    }\n    r = requests.get(url, params=params, timeout=30)\n    r.raise_for_status()\n    data = r.json().get('results', [])\n    for w in data:\n        all_works[w['id']] = w\n    time.sleep(1)\n\nkw = ['detect','detection','machine-generated','ai-generated','language model','llm','paraphr','rewrite','watermark','adversarial','humanize']\nrows = []\nfor w in all_works.values():\n    title = w.get('title') or ''\n    abstract = ''\n    inv = w.get('abstract_inverted_index')\n    if inv:\n        words = sorted(((pos, word) for word, poss in inv.items() for pos in poss), key=lambda x: x[0])\n        abstract = ' '.join(word for _,word in words)\n    text = (title + ' ' + abstract).lower()\n    rel = sum(1 for k in kw if k in text)\n    oa = w.get('open_access') or {}\n    loc = w.get('primary_location') or {}\n    pdf = oa.get('oa_url') or loc.get('pdf_url') or ''\n    doi = w.get('doi') or ''\n    rows.append({\n      'id': w.get('id'),\n      'title': title,\n      'year': w.get('publication_year'),\n      'authors': ', '.join(a['author']['display_name'] for a in (w.get('authorships') or [])[:8]),\n      'cited_by_count': w.get('cited_by_count',0),\n      'venue': (w.get('primary_location') or {}).get('source',{}).get('display_name',''),\n      'doi': doi,\n      'landing_page': (w.get('primary_location') or {}).get('landing_page_url',''),\n      'pdf_url': pdf,\n      'abstract': re.sub(r'\\\\s+',' ',abstract).strip(),\n      'relevance': rel,\n      'is_oa': oa.get('is_oa'),\n    })\nrows.sort(key=lambda x:(x['relevance'], x['cited_by_count'], x['year'] or 0), reverse=True)\nwith open('papers/manual_search_results.json','w') as f:\n    json.dump(rows,f,indent=2)\nprint('total',len(rows))\nfor i,r in enumerate(rows[:35],1):\n    print(f\\\"{i:02d}. rel={r['relevance']} cites={r['cited_by_count']} year={r['year']} pdf={'yes' if r['pdf_url'] else 'no'} | {r['title']}\\\")\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}

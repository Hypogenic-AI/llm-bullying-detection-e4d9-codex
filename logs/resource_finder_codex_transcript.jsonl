{"type":"item.started","item":{"id":"item_21","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nimport requests, json, re, time\nqueries = [\n  'AI-generated text detection large language models',\n  'adversarial attacks against AI text detectors',\n  'paraphrasing to evade machine-generated text detection',\n  'watermarking large language models detection',\n  'humanization of LLM text'\n]\nfields = 'title,year,authors,abstract,citationCount,openAccessPdf,url,publicationVenue,externalIds'\nall_papers = {}\nfor q in queries:\n    url = 'https://api.semanticscholar.org/graph/v1/paper/search'\n    params = {'query': q, 'limit': 20, 'fields': fields}\n    r = requests.get(url, params=params, timeout=30)\n    r.raise_for_status()\n    data = r.json().get('data',[])\n    for p in data:\n        pid = p.get('paperId')\n        if not pid: continue\n        all_papers[pid] = p\n    time.sleep(1.5)\n\nkw = ['detect','detection','machine-generated','ai-generated','language model','llm','paraphr','rewrite','watermark','adversarial','humanize']\nrows = []\nfor p in all_papers.values():\n    t = ((p.get('title') or '') + ' ' + (p.get('abstract') or '')).lower()\n    rel = sum(1 for k in kw if k in t)\n    pdf = (p.get('openAccessPdf') or {}).get('url','')\n    rows.append({\n        'paperId': p.get('paperId'),\n        'title': p.get('title'),\n        'year': p.get('year'),\n        'authors': ', '.join(a.get('name','') for a in (p.get('authors') or [])[:8]),\n        'citationCount': p.get('citationCount',0),\n        'abstract': re.sub(r'\\\\s+',' ', (p.get('abstract') or '')).strip(),\n        'pdf_url': pdf,\n        's2_url': p.get('url'),\n        'venue': (p.get('publicationVenue') or {}).get('name',''),\n        'externalIds': p.get('externalIds') or {},\n        'relevance': rel,\n    })\nrows.sort(key=lambda x:(x['relevance'], x['citationCount'], x['year'] or 0), reverse=True)\nwith open('papers/manual_search_results.json','w') as f:\n    json.dump(rows,f,indent=2)\nprint('total', len(rows))\nfor i,r in enumerate(rows[:30],1):\n    print(f\\\"{i:02d}. [rel={r['relevance']}] [c={r['citationCount']}] [{r['year']}] {r['title']} | pdf={'yes' if r['pdf_url'] else 'no'}\\\")\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}

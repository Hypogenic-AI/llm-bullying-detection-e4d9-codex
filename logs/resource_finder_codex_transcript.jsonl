{"type":"item.started","item":{"id":"item_25","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nimport json, re, os, requests\nfrom pathlib import Path\n\nwith open('papers/manual_search_results.json') as f:\n    rows = json.load(f)\n\nselected = []\nseen_titles=set()\nfor r in rows:\n    t=(r['title'] or '').strip()\n    tl=t.lower()\n    if tl in seen_titles:\n        continue\n    seen_titles.add(tl)\n    if not r.get('pdf_url'):\n        continue\n    # topic filter\n    keep_kw=['detect','detection','ai-generated','machine-generated','watermark','evade','adversarial','paraphr','humaniz','llm']\n    txt=(t+' '+(r.get('abstract') or '')).lower()\n    if sum(k in txt for k in keep_kw) < 2:\n        continue\n    selected.append(r)\n    if len(selected)>=12:\n        break\n\nPath('papers').mkdir(exist_ok=True)\nwith open('papers/selected_papers.json','w') as f:\n    json.dump(selected,f,indent=2)\n\nprint('selected',len(selected))\nfor i,r in enumerate(selected,1):\n    print(f\\\"{i:02d}. {r['year']} | {r['title']} | {r['pdf_url']}\\\")\n\n# download\nfor i,r in enumerate(selected,1):\n    title = r['title']\n    slug = re.sub(r'[\"'^a-zA-Z0-9]+'\"','_', title).strip('_').lower()[:70]\n    year = r.get('year') or 'unknown'\n    fn = f\\\"papers/{year}_{slug}.pdf\\\"\n    url = r['pdf_url']\n    try:\n        resp = requests.get(url, timeout=60, allow_redirects=True)\n        resp.raise_for_status()\n        ctype = resp.headers.get('content-type','').lower()\n        # accept pdf or octet stream; if html likely not pdf\n        if ('pdf' not in ctype) and (not resp.content.startswith(b'%PDF')):\n            print(f\\\"WARN non-pdf content for {title}: {ctype}\\\")\n            continue\n        with open(fn,'wb') as out:\n            out.write(resp.content)\n        if os.path.getsize(fn) < 50000:\n            print(f\\\"WARN tiny file {fn} size={os.path.getsize(fn)}\\\")\n        else:\n            print(f\\\"OK {fn} {os.path.getsize(fn)} bytes\\\")\n    except Exception as e:\n        print(f\\\"FAIL {title}: {e}\\\")\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}

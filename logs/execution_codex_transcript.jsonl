{"type":"item.started","item":{"id":"item_81","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - <<'PY'\nimport pandas as pd, numpy as np\nsc=pd.read_csv('results/scored_texts.csv')\n# outliers on detector probs by z-score >3\nouts={}\nfor c in ['word_ai_prob','stylometric_ai_prob']:\n    z=(sc[c]-sc[c].mean())/sc[c].std(ddof=1)\n    outs[c]=int((np.abs(z)>3).sum())\nprint('outliers',outs)\n# paired improvements\nfor det in ['word_ai_prob','stylometric_ai_prob']:\n    for src in ['fresh_model_generation','external_ai_text']:\n        sub=sc[sc.source_type==src]\n        a=sub[sub.condition=='iterative_final'].sort_values('item_id')[det].to_numpy()\n        b=sub[sub.condition=='one_shot'].sort_values('item_id')[det].to_numpy()\n        print(det,src,'iter-one mean',float((a-b).mean()))\n# pass rates difference\npr=pd.read_csv('results/pass_rates.csv')\nfor det in pr.detector.unique():\n    for src in pr.source_type.unique():\n        d=pr[(pr.detector==det)&(pr.source_type==src)]\n        if {'iterative_final','one_shot'}.issubset(set(d.condition)):\n            i=float(d[d.condition=='iterative_final'].pass_rate.iloc[0])\n            o=float(d[d.condition=='one_shot'].pass_rate.iloc[0])\n            print('pass_delta',det,src,i-o)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
